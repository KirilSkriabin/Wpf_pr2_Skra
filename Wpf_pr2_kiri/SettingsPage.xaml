<Page
    x:Class="Wpf_pr2_kiri.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Wpf_pr2_kiri"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SettingsPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Border
            MinWidth="350"
            MinHeight="450"
            Margin="100"
            Background="#1E1E1E"
            CornerRadius="20">

            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="25"
                    Opacity="0.6"
                    ShadowDepth="0"
                    Color="Black" />
            </Border.Effect>

            <StackPanel
                Width="300"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <TextBlock
                    Margin="0,0,0,40"
                    HorizontalAlignment="Center"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="#E0E0E0"
                    Text="{DynamicResource m_Settings}" />

                <TextBlock
                    Margin="0,0,0,10"
                    Foreground="#AAAAAA"
                    Text="{DynamicResource m_ChooseLang}" />

                <ComboBox
                    x:Name="ComboLang"
                    Height="45"
                    Margin="0,0,0,30"
                    SelectionChanged="ComboLang_SelectionChanged">
                    <ComboBoxItem Content="Українська" Tag="uk-UA" />
                    <ComboBoxItem Content="English" Tag="en-US" />
                </ComboBox>

                <Button
                    Height="55"
                    Background="#2D2D2D"
                    Click="BtnBack_Click"
                    Content="{DynamicResource m_Back}"
                    Foreground="White">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10" />
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Page>
