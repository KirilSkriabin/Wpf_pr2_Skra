<Page
    x:Class="Wpf_pr2_kiri.Views.CharacterSheetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Wpf_pr2_kiri.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="CharacterSheetPage"
    mc:Ignorable="d">

    <Grid Margin="0,0,10,30">
        <Button
            x:Name="BtnBack"
            Margin="10"
            Padding="10,5"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="#121212"
            BorderThickness="0"
            Click="BtnBack_Click"
            Content="{DynamicResource m_Back}"
            Foreground="White">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5" />
                </Style>
            </Button.Resources>
        </Button>
        <Viewbox Stretch="Uniform">
            <Border
                Width="603"
                Height="318"
                Margin="50"
                Background="#121212"
                CornerRadius="15">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="25"
                        Opacity="0.6"
                        ShadowDepth="0"
                        Color="Black" />
                </Border.Effect>
                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl
                        Grid.Row="1"
                        Margin="20"
                        Background="Transparent"
                        BorderThickness="0">

                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Height" Value="40" />
                                <Setter Property="MinWidth" Value="100" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border
                                                x:Name="Border"
                                                Margin="2,0"
                                                Background="#1E1E1E"
                                                CornerRadius="5,5,0,0">
                                                <ContentPresenter
                                                    x:Name="ContentSite"
                                                    Margin="12,2"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    ContentSource="Header" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="White" />
                                                    <Setter Property="Foreground" Value="Black" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="False">
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <TabItem Header="General 👤">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                    <Border
                                        Margin="0,0,0,6"
                                        Padding="6"
                                        Background="#1E1E1E"
                                        CornerRadius="8,25,25,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="35" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="8"
                                                    Foreground="#666"
                                                    Text="{DynamicResource m_Lvl}" />
                                                <TextBox
                                                    x:Name="TxtLevel"
                                                    HorizontalAlignment="Center"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="16"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    LostFocus="Level_LostFocus"
                                                    PreviewTextInput="NumberValidationTextBox"
                                                    Text="1"
                                                    TextChanged="TxtLevel_TextChanged" />
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Column="1"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                                <TextBox
                                                    x:Name="TxtCharName"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    GotFocus="TextBox_GotFocus"
                                                    LostFocus="Name_LostFocus"
                                                    Text="{DynamicResource m_CharNamePlaceholder}" />
                                                <TextBox
                                                    x:Name="TxtCharRaceClass"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="9"
                                                    Foreground="#666"
                                                    GotFocus="TextBox_GotFocus"
                                                    LostFocus="Race_LostFocus"
                                                    Text="{DynamicResource m_CharRacePlaceholder}" TextChanged="TxtCharRaceClass_TextChanged" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border
                                        Padding="8"
                                        Background="#1E1E1E"
                                        CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock
                                                Margin="0,0,0,6"
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="White"
                                                Text="{DynamicResource m_HitPoints}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="55" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border
                                                    Grid.Column="0"
                                                    Padding="2"
                                                    Background="#2D2D2D"
                                                    CornerRadius="6">
                                                    <StackPanel>
                                                        <Button
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="BtnHeal_Click"
                                                            Content="{DynamicResource m_Heal}"
                                                            FontSize="8"
                                                            Foreground="#82FF82" />
                                                        <TextBox
                                                            x:Name="TxtHpChange"
                                                            Margin="0,2"
                                                            HorizontalContentAlignment="Center"
                                                            Background="#333"
                                                            BorderThickness="0"
                                                            FontSize="11"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            PreviewTextInput="NumberValidationTextBox"
                                                            Text="0" />
                                                        <Button
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Click="BtnDamage_Click"
                                                            Content="{DynamicResource m_Damage}"
                                                            FontSize="8"
                                                            Foreground="#FF8282" />
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="5,0,0,0"
                                                    VerticalAlignment="Center">
                                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                        <TextBox
                                                            x:Name="TxtCurrentHp"
                                                            Width="30"
                                                            HorizontalContentAlignment="Right"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            FontSize="18"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            PreviewTextInput="NumberValidationTextBox"
                                                            Text="0" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="16"
                                                            Foreground="#444"
                                                            Text="/" />
                                                        <TextBox
                                                            x:Name="TxtMaxHp"
                                                            Width="30"
                                                            HorizontalContentAlignment="Left"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            FontSize="16"
                                                            FontWeight="Bold"
                                                            Foreground="#666"
                                                            PreviewTextInput="NumberValidationTextBox"
                                                            Text="0" />
                                                    </StackPanel>
                                                    <StackPanel
                                                        Margin="0,2,0,0"
                                                        HorizontalAlignment="Center"
                                                        Orientation="Horizontal">
                                                        <TextBlock
                                                            FontSize="8"
                                                            Foreground="#555"
                                                            Text="Prof: " />
                                                        <TextBlock
                                                            x:Name="LblProfBonus"
                                                            FontSize="8"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="+2" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <UniformGrid Columns="6">

                                        <StackPanel Margin="2">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="8"
                                                Foreground="#666"
                                                Text="{DynamicResource m_Str}" />
                                            <Grid
                                                Width="36"
                                                Height="36"
                                                Margin="0,2">
                                                <Button
                                                    x:Name="BtnRollStr"
                                                    Width="36"
                                                    HorizontalAlignment="Left"
                                                    Background="#2D2D2D"
                                                    Click="BtnRollStat_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="18" />
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <TextBlock
                                                    x:Name="TxtModStr"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    IsHitTestVisible="False"
                                                    Text="+0" />
                                            </Grid>
                                            <TextBox
                                                x:Name="TxtStatStr"
                                                Width="28"
                                                HorizontalContentAlignment="Center"
                                                Background="#333"
                                                BorderThickness="0"
                                                FontSize="10"
                                                Foreground="White"
                                                PreviewTextInput="NumberValidationTextBox"
                                                Text="10"
                                                TextChanged="Stat_TextChanged" />
                                        </StackPanel>

                                        <StackPanel Margin="2">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="8"
                                                Foreground="#666"
                                                Text="{DynamicResource m_Dex}" />
                                            <Grid
                                                Width="36"
                                                Height="36"
                                                Margin="0,2">
                                                <Button
                                                    x:Name="BtnRollDex"
                                                    Background="#2D2D2D"
                                                    Click="BtnRollStat_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="18" />
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <TextBlock
                                                    x:Name="TxtModDex"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    IsHitTestVisible="False"
                                                    Text="+0" />
                                            </Grid>
                                            <TextBox
                                                x:Name="TxtStatDex"
                                                Width="28"
                                                HorizontalContentAlignment="Center"
                                                Background="#333"
                                                BorderThickness="0"
                                                FontSize="10"
                                                Foreground="White"
                                                PreviewTextInput="NumberValidationTextBox"
                                                Text="10"
                                                TextChanged="Stat_TextChanged" />
                                        </StackPanel>

                                        <StackPanel Margin="2">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="8"
                                                Foreground="#666"
                                                Text="{DynamicResource m_Con}" />
                                            <Grid
                                                Width="36"
                                                Height="36"
                                                Margin="0,2">
                                                <Button
                                                    x:Name="BtnRollCon"
                                                    Background="#2D2D2D"
                                                    Click="BtnRollStat_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="18" />
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <TextBlock
                                                    x:Name="TxtModCon"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    IsHitTestVisible="False"
                                                    Text="+0" />
                                            </Grid>
                                            <TextBox
                                                x:Name="TxtStatCon"
                                                Width="28"
                                                HorizontalContentAlignment="Center"
                                                Background="#333"
                                                BorderThickness="0"
                                                FontSize="10"
                                                Foreground="White"
                                                PreviewTextInput="NumberValidationTextBox"
                                                Text="10"
                                                TextChanged="Stat_TextChanged" />
                                        </StackPanel>

                                        <StackPanel Margin="2">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="8"
                                                Foreground="#666"
                                                Text="{DynamicResource m_Int}" />
                                            <Grid
                                                Width="36"
                                                Height="36"
                                                Margin="0,2">
                                                <Button
                                                    x:Name="BtnRollInt"
                                                    Background="#2D2D2D"
                                                    Click="BtnRollStat_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="18" />
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <TextBlock
                                                    x:Name="TxtModInt"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    IsHitTestVisible="False"
                                                    Text="+0" />
                                            </Grid>
                                            <TextBox
                                                x:Name="TxtStatInt"
                                                Width="28"
                                                HorizontalContentAlignment="Center"
                                                Background="#333"
                                                BorderThickness="0"
                                                FontSize="10"
                                                Foreground="White"
                                                PreviewTextInput="NumberValidationTextBox"
                                                Text="10"
                                                TextChanged="Stat_TextChanged" />
                                        </StackPanel>

                                        <StackPanel Margin="2">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="8"
                                                Foreground="#666"
                                                Text="{DynamicResource m_Wis}" />
                                            <Grid
                                                Width="36"
                                                Height="36"
                                                Margin="0,2">
                                                <Button
                                                    x:Name="BtnRollWis"
                                                    Background="#2D2D2D"
                                                    Click="BtnRollStat_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="18" />
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <TextBlock
                                                    x:Name="TxtModWis"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    IsHitTestVisible="False"
                                                    Text="+0" />
                                            </Grid>
                                            <TextBox
                                                x:Name="TxtStatWis"
                                                Width="28"
                                                HorizontalContentAlignment="Center"
                                                Background="#333"
                                                BorderThickness="0"
                                                FontSize="10"
                                                Foreground="White"
                                                PreviewTextInput="NumberValidationTextBox"
                                                Text="10"
                                                TextChanged="Stat_TextChanged" />
                                        </StackPanel>

                                        <StackPanel Margin="2">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="8"
                                                Foreground="#666"
                                                Text="{DynamicResource m_Cha}" />
                                            <Grid
                                                Width="36"
                                                Height="36"
                                                Margin="0,2">
                                                <Button
                                                    x:Name="BtnRollCha"
                                                    Background="#2D2D2D"
                                                    Click="BtnRollStat_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="18" />
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <TextBlock
                                                    x:Name="TxtModCha"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    IsHitTestVisible="False"
                                                    Text="+0" />
                                            </Grid>
                                            <TextBox
                                                x:Name="TxtStatCha"
                                                Width="28"
                                                HorizontalContentAlignment="Center"
                                                Background="#333"
                                                BorderThickness="0"
                                                FontSize="10"
                                                Foreground="White"
                                                PreviewTextInput="NumberValidationTextBox"
                                                Text="10"
                                                TextChanged="Stat_TextChanged" />
                                        </StackPanel>

                                    </UniformGrid>
                                    <UniformGrid Margin="0,15,0,0" Columns="3">
                                        <Border
                                            Margin="5"
                                            Padding="10"
                                            Background="#1E1E1E"
                                            CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#666"
                                                    Text="{DynamicResource m_ArmorClass}" />
                                                <TextBlock
                                                    x:Name="LblTotalAC"
                                                    Margin="0,5"
                                                    HorizontalAlignment="Center"
                                                    FontSize="22"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="10" />
                                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                    <TextBox
                                                        x:Name="TxtBaseArmor"
                                                        Width="25"
                                                        HorizontalContentAlignment="Center"
                                                        Background="#333"
                                                        BorderThickness="0"
                                                        Foreground="White"
                                                        Text="10"
                                                        TextChanged="UpdateAC" />
                                                    <ComboBox
                                                        x:Name="ComboACMod"
                                                        Width="60"
                                                        Margin="5,0,0,0"
                                                        FontSize="9"
                                                        SelectionChanged="UpdateAC">
                                                        <ComboBoxItem Content="None" IsSelected="True" />
                                                        <ComboBoxItem Content="+ DEX" />
                                                        <ComboBoxItem Content="+ CON" />
                                                    </ComboBox>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border
                                            Margin="5"
                                            Padding="10"
                                            Background="#1E1E1E"
                                            CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#666"
                                                    Text="{DynamicResource m_Initiative}" />
                                                <TextBlock
                                                    x:Name="LblTotalIni"
                                                    Margin="0,5"
                                                    HorizontalAlignment="Center"
                                                    FontSize="22"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="+0" />
                                                <TextBox
                                                    x:Name="TxtBonusIni"
                                                    Width="30"
                                                    HorizontalAlignment="Center"
                                                    HorizontalContentAlignment="Center"
                                                    Background="#333"
                                                    BorderThickness="0"
                                                    Foreground="White"
                                                    Text="0"
                                                    TextChanged="UpdateIni" />
                                            </StackPanel>
                                        </Border>

                                        <Border
                                            Margin="5"
                                            Padding="10"
                                            Background="#1E1E1E"
                                            CornerRadius="8">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#666"
                                                    Text="{DynamicResource m_Speed}" />
                                                <StackPanel
                                                    Margin="0,5"
                                                    HorizontalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <TextBox
                                                        x:Name="TxtSpeed"
                                                        VerticalAlignment="Center"
                                                        HorizontalContentAlignment="Center"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="22"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        PreviewTextInput="NumberValidationTextBox"
                                                        Text="30" />
                                                    <TextBlock
                                                        Margin="2,0,0,4"
                                                        VerticalAlignment="Bottom"
                                                        FontSize="10"
                                                        Foreground="#444"
                                                        Text="ft" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                    <StackPanel Margin="0,15,0,0" Orientation="Horizontal" />
                                </StackPanel>

                                <Grid
                                    x:Name="RollOverlay"
                                    Grid.ColumnSpan="2"
                                    Background="#A6000000"
                                    Visibility="Collapsed">
                                    <Border
                                        Width="130"
                                        Height="130"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#2D2D2D"
                                        CornerRadius="12">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                x:Name="TxtRollTitle"
                                                HorizontalAlignment="Center"
                                                FontSize="9"
                                                Foreground="#888"
                                                Text="ROLL" />
                                            <TextBlock
                                                x:Name="TxtRollResult"
                                                HorizontalAlignment="Center"
                                                FontSize="42"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="20" />
                                            <TextBlock
                                                x:Name="TxtRollDetails"
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                Foreground="#555"
                                                Text="15 + 5" />
                                            <Button
                                                Width="40"
                                                Margin="0,10,0,0"
                                                Background="#444"
                                                BorderThickness="0"
                                                Click="CloseRoll_Click"
                                                Content="OK"
                                                Foreground="White" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Attacks ⚔️">
                            <Grid Margin="10">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Text="Тут будуть атаки" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="Spells ✨">
                            <Grid Margin="10">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Text="Тут буде книга заклинань" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="Items 💼">
                            <Grid Margin="10">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Text="Тут буде інвентар" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="Bio 📜">
                            <Grid Margin="10">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column="0"
                                        Margin="5"
                                        Padding="10"
                                        Background="#252525"
                                        CornerRadius="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                Grid.Row="0"
                                                Margin="0,0,0,10"
                                                HorizontalAlignment="Center"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="{DynamicResource m_Backstory}" />

                                            <TextBox
                                                x:Name="TxtBackstory"
                                                Grid.Row="1"
                                                Padding="8"
                                                AcceptsReturn="True"
                                                Background="#333"
                                                BorderThickness="0"
                                                FontSize="14"
                                                Foreground="White"
                                                ScrollViewer.CanContentScroll="True"
                                                TextWrapping="Wrap"
                                                VerticalScrollBarVisibility="Auto" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        Grid.Column="1"
                                        Margin="5"
                                        Padding="10"
                                        Background="#252525"
                                        CornerRadius="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                Grid.Row="0"
                                                Margin="0,0,0,10"
                                                HorizontalAlignment="Center"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="{DynamicResource m_AlliesNotes}" />

                                            <TextBox
                                                x:Name="TxtAlliesNotes"
                                                Grid.Row="1"
                                                Padding="8"
                                                AcceptsReturn="True"
                                                Background="#333"
                                                BorderThickness="0"
                                                FontSize="14"
                                                Foreground="White"
                                                ScrollViewer.CanContentScroll="True"
                                                TextWrapping="Wrap"
                                                VerticalScrollBarVisibility="Auto" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Grid>
            </Border>
        </Viewbox>
    </Grid>
</Page>
