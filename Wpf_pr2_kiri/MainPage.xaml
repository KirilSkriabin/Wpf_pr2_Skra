<Page
    x:Class="Wpf_pr2_kiri.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Wpf_pr2_kiri"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Border
            Margin="100"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#BABABA"
            CornerRadius="20">

            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="25"
                    Opacity="0.6"
                    ShadowDepth="0"
                    Color="Black" />
            </Border.Effect>

            <StackPanel
                MaxWidth="350"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <TextBlock
                    Margin="0,0,0,40"
                    HorizontalAlignment="Center"
                    FontFamily="Segoe UI Semibold"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="#E0E0E0"
                    Text="D&amp;D HELPER" />

                <Button
                    x:Name="BtnStart"
                    Width="300"
                    Height="55"
                    Margin="0,8"
                    Background="#DEDEDE"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1"
                    Click="BtnStart_Click"
                    Content="{DynamicResource m_Start}"
                    Cursor="Hand"
                    FontSize="16"
                    Foreground="White">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10" />
                        </Style>
                    </Button.Resources>
                </Button>

                <Button
                    x:Name="BtnSettings"
                    Width="300"
                    Height="55"
                    Margin="0,8"
                    Background="#DEDEDE"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1"
                    Click="BtnSettings_Click"
                    Content="{DynamicResource m_Settings}"
                    Cursor="Hand"
                    FontSize="16"
                    Foreground="White">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10" />
                        </Style>
                    </Button.Resources>
                </Button>

                <Button
                    x:Name="BtnExit"
                    Width="300"
                    Height="55"
                    Margin="0,8"
                    Background="#451A1A"
                    BorderBrush="#632525"
                    BorderThickness="1"
                    Click="BtnExit_Click"
                    Content="{DynamicResource m_Exit}"
                    Cursor="Hand"
                    FontSize="16"
                    Foreground="#FF8585">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10" />
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Page>
